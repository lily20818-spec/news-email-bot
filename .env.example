# Gmail 帳號（建議使用專用的寄件帳號）
GMAIL_USER=your_email@gmail.com

# Gmail 應用程式密碼（App Password，16 碼）
GMAIL_APP_PASSWORD=your_app_password

# 收件人，多個用逗號分隔
RECIPIENTS=recipient1@example.com,recipient2@example.com

# RSS 來源，多個用逗號分隔
RSS_FEEDS=https://www.cnbc.com/id/100003114/device/rss/rss.html,https://feeds.a.dj.com/rss/RSSMarketsMain.xml

# 每封信最多幾則新聞
MAX_ITEMS=10

# 寄送主旨
EMAIL_SUBJECT=每日財經新聞摘要

# 時區（排程顯示用）
TIMEZONE=Asia/Taipei
